{
  "manifest_version": 3,
  "name": "Urgencias Pro v13.0 - Extractor",
  "version": "13.0",
  "author": "Dan Chojrin",
  "description": "Extractor de cuadrantes de aTurnos y Distribuidor de Urgencias",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["https://*.aturnos.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.aturnos.com/*"],
      "js": ["extractor.js"]
    }
  ]
}
